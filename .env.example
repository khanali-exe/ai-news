# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=ainews
POSTGRES_PASSWORD=ainews_secret
POSTGRES_DB=ainews

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI (OpenAI or compatible) ────────────────────────────────────────────────
# Required: get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: use a different base URL for OpenAI-compatible providers (e.g. Together, Groq)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for processing (gpt-4o-mini is fast and cheap)
AI_MODEL=gpt-4o-mini

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
ENVIRONMENT=development

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Token for Next.js ISR revalidation (keep secret)
REVALIDATE_TOKEN=change_this_too
